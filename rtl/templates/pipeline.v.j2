module pipeline #(
    parameter DATA_WIDTH = {{ DATA_WIDTH }},
    parameter PIPELINE_DEPTH = {{ PIPELINE_DEPTH }}
)(
    input clk,
    input rst,
    input [DATA_WIDTH-1:0] data_in,
    output [DATA_WIDTH-1:0] data_out
);

    {% if PIPELINE_DEPTH == 0 %}
        assign data_out = data_in;
    {% else %}

    reg [DATA_WIDTH-1:0] stage [0:PIPELINE_DEPTH-1];
    integer i;

    always @(posedge clk) begin
        if (rst) begin
            for (i = 0; i < PIPELINE_DEPTH; i = i + 1)
                stage[i] <= 0;
        end else begin
            stage[0] <= data_in;
            for (i = 1; i < PIPELINE_DEPTH; i = i + 1)
                stage[i] <= stage[i-1];
        end
    end

    assign data_out = stage[PIPELINE_DEPTH-1];

    {% endif %}

endmodule
