module arbiter #(
    parameter BANKS = {{ BANKS }}
)(
    input clk,
    input rst,
    input [BANKS-1:0] req,
    output reg [BANKS-1:0] grant
);

    integer i;

    always @(*) begin
        grant = 0;
        for (i = 0; i < BANKS; i = i + 1) begin
            if (req[i]) begin
                grant = (1 << i);
            end
        end
    end

endmodule